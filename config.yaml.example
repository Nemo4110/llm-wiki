# LLM-Wiki 配置文件
# 将此文件复制为 config.yaml 并修改为你的环境

embedding:
  # 是否启用 embedding 检索（默认 false，保持纯符号导航）
  enabled: false

  # 提供者: ollama | openai | mcp
  provider: ollama

  # 模型名称（Provider 特定）
  model: nomic-embed-text

  ollama:
    base_url: http://localhost:11434

  openai:
    api_key: "${OPENAI_API_KEY}"
    # 可选：自定义 endpoint（如兼容 OpenAI 的第三方服务）
    # base_url: https://api.openai.com/v1

  mcp:
    # 传输方式: stdio | sse
    transport: stdio
    # stdio 配置
    command: python
    args: ["-m", "my_embedding_server"]
    env: {}
    # sse 配置
    # url: http://localhost:3000/sse
    # 工具名（可选，留空则自动发现）
    tool_name: embed

retrieval:
  # 混合搜索返回的 top-k 结果数
  top_k: 10

  # 各信号权重（总和不必为 1，仅影响相对比例）
  keyword_weight: 0.3
  vector_weight: 0.5
  link_weight: 0.2

  # 是否启用链接遍历增强
  enable_link_traversal: true
